# Disable directory browsing
Options -Indexes

# Block access to hidden files (such as .env, .git, etc.)
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Secure root folders and sensitive files, and redirect to public/
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to sensitive directories
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor)($|/) - [F,L]

    # Block access to sensitive root files
    RewriteRule ^(composer\.(json|lock)|package\.(json|lock)|vite\.config\.js|artisan|phpunit\.xml) - [F,L]

    # Silently route all other requests to the public/ folder
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>